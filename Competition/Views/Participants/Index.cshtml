@model IEnumerable<Participant>
@{
    ViewData["Title"] = "Список учасників";
}

<div class="container mt-4">
    <h2 class="mb-4">Змагання з пауерліфтингу: Список учасників</h2>
    <a asp-action="Create" class="mb-3 btn btn-primary">
        + Додати нового учасника
    </a>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ПІБ</th>
                <th>Заклад</th>
                <th>Тренер</th>
                <th>Присяд</th>
                <th>Жим</th>
                <th>Станова</th>
                <th>Сума</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.Institution.Name</td>
                    <td>@item.CoachName</td>
                    <td>@item.Squat</td>
                    <td>@item.BenchPress</td>
                    <td>@item.Deadlift</td>
                    <td>@item.TotalScore</td>
                    <td>
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
