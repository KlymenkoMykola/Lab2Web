@model IEnumerable<Participant>
@{
    ViewData["Title"] = "Список учасників";
}

<div class="container mt-4">
    <h2 class="mb-4">Змагання з пауерліфтингу: Список учасників</h2>
    <a asp-action="Create" class="mb-3 btn btn-primary">
        + Додати нового учасника
    </a>

    <div class="table-responsive shadow-sm rounded" style="max-height: 500px; overflow-y: auto;">

        <table class="table table-bordered table-hover mb-0" style="border-color: #b0bec5;">

            <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                <tr>
                    <th>ПІБ</th>
                    <th>Навчальний заклад</th>
                    <th>Тренер</th>
                    <th style="background-color: #cce5ff; color: #000;">Присяд</th>
                    <th style="background-color: #cce5ff; color: #000;">Жим</th>
                    <th style="background-color: #cce5ff; color: #000;">Тяга</th>
                    <th style="background-color: #fff3cd; color: #000;">Сума</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Institution?.Name</td>
                        <td>@item.CoachName</td>

                        <td style="background-color: #e6f2ff;">@item.Squat кг</td>
                        <td style="background-color: #e6f2ff;">@item.BenchPress кг</td>
                        <td style="background-color: #e6f2ff;">@item.Deadlift кг</td>

                        <td style="background-color: #fffde6;" class="text-success fw-bold">@item.TotalScore кг</td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Редагувати">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Видалити">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
