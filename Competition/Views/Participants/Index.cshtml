@model IEnumerable<Participant>
@{
    ViewData["Title"] = "Список учасників";
}

<div class="container mt-4">
    <h2 class="mb-4">Змагання з пауерліфтингу: Список учасників</h2>
    <a asp-action="Create" class="mb-3 btn btn-primary">
        + Додати нового учасника
    </a>
    <form asp-action="Index" method="get" class="mb-4">
        <div class="row align-items-center">
            <div class="col-md-6 col-lg-4">
                <div class="input-group shadow-sm">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-secondary" placeholder="Пошук за прізвищем..." />

                    <button type="submit" class="btn btn-secondary">
                        <i class="bi bi-search"></i> Знайти
                    </button>
                </div>
            </div>
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">
                        <i class="bi bi-x-circle"></i> Скинути пошук
                    </a>
                }
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm rounded" style="max-height: 500px; overflow-y: auto;">

        <table class="table table-bordered table-hover mb-0 align-middle" style="border-color: #b0bec5;">

            <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                <tr>
                    <th>ПІБ</th>
                    <th>Навчальний заклад</th>
                    <th>Тренер</th>
                    <th style="background-color: #cce5ff; color: #000;">Присяд</th>
                    <th style="background-color: #cce5ff; color: #000;">Жим</th>
                    <th style="background-color: #cce5ff; color: #000;">Тяга</th>
                    <th style="background-color: #fff3cd; color: #000;">Сума</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody">
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Institution?.Name</td>
                        <td>@item.CoachName</td>

                        <td style="background-color: #e6f2ff;">@item.Squat кг</td>
                        <td style="background-color: #e6f2ff;">@item.BenchPress кг</td>
                        <td style="background-color: #e6f2ff;">@item.Deadlift кг</td>

                        <td style="background-color: #fffde6;" class="text-success fw-bold">@item.TotalScore кг</td>

                        <td class="text-nowrap">
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-warning" title="Редагувати">
                                <i class="bi bi-pencil-square" style="pointer-events: none;"></i>
                            </a>

                            <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-outline-danger" title="Видалити">
                                <i class="bi bi-trash3" style="pointer-events: none;"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
